# Apache Configuration
# Enable URL Rewriting and Security Headers

# Enable Rewrite Engine
RewriteEngine On
RewriteBase /

# ================================================
# –Ш–Ш-–Ъ–Ю–Э–°–£–Ы–ђ–Ґ–Р–Э–Ґ (–Є–Ј–Њ–ї–Є—А–Њ–≤–∞–љ–љ—Л–є –Ї–Њ–љ—В–µ–є–љ–µ—А)
# ================================================
# –Я—А–Њ–Ї—Б–Є—А—Г–µ–Љ /ai-chat/api/* вЖТ ai-consultant:80/api/* —З–µ—А–µ–Ј mod_proxy.
# –Х—Б–ї–Є –Ї–Њ–љ—В–µ–є–љ–µ—А —Г–њ–∞–ї вАФ Apache –≤–µ—А–љ—С—В 503, JS –≤–Є–і–ґ–µ—В–∞ –њ–Њ–Ї–∞–ґ–µ—В offline-–±–∞–љ–љ–µ—А
# (ProxyPass –љ–µ —А–∞–±–Њ—В–∞–µ—В –≤ .htaccess; –Є—Б–њ–Њ–ї—М–Ј—Г–µ–Љ RewriteRule —Б [P])
RewriteRule ^ai-chat/api/(.*)$ http://ai-consultant:80/api/$1 [P,L]

# www вЖТ non-www (301)
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# HTTPS Redirect (–њ—А–Њ–њ—Г—Б–Ї–∞–µ—В localhost)
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{HTTP_HOST} !^localhost [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Trailing slash: –Ї–∞–љ–Њ–љ–Є—З–µ—Б–Ї–Є–є URL вАФ —Б–Њ —Б–ї—Н—И–µ–Љ –љ–∞ –Ї–Њ–љ—Ж–µ.
# –Я—А–Є–Љ–µ–љ—П–µ—В—Б—П —В–Њ–ї—М–Ї–Њ –Ї GET/HEAD, –Ї URL –±–µ–Ј —А–∞—Б—И–Є—А–µ–љ–Є—П —Д–∞–є–ї–∞ –Є –љ–µ –Ї —Б—Г—Й–µ—Б—В–≤—Г—О—Й–Є–Љ —Д–∞–є–ї–∞–Љ/–њ–∞–њ–Ї–∞–Љ.
# –ѓ–≤–љ—Л–є https:// –≤ Location вАФ –Є–љ–∞—З–µ Apache –Ј–∞ nginx-–њ—А–Њ–Ї—Б–Є —В–µ—А—П–µ—В —Б—Е–µ–Љ—Г –Є –Њ—В–і–∞—С—В http://
RewriteCond %{REQUEST_METHOD} ^(GET|HEAD)$
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]+$
RewriteCond %{REQUEST_URI} !/$
RewriteRule ^(.+)$ https://%{HTTP_HOST}/$1/ [R=301,L]

# ================================================
# APPLE UNIVERSAL LINKS (iOS-–њ—А–Є–ї–Њ–ґ–µ–љ–Є—П —Г —Б–∞–є—В–∞ –љ–µ—В)
# –Т–Њ–Ј–≤—А–∞—Й–∞–µ–Љ 410 Gone, —З—В–Њ–±—Л iOS –Є GSC –њ—А–µ–Ї—А–∞—В–Є–ї–Є –Ј–∞–њ—А–Њ—Б—Л
# ================================================
RewriteRule ^(\.well-known/)?apple-app-site-association$ - [R=410,L]

# ================================================
# OG-–Ъ–Р–†–Ґ–Ш–Э–Ъ–Ш –Ф–Ы–ѓ –°–Ю–¶–°–Х–Ґ–Х–Щ
# ================================================
RewriteRule ^og-image/ad/([a-z]+)/([a-z0-9-]+)\.jpg$ api/og-image.php?mode=ad&type=$1&slug=$2 [L]
RewriteRule ^og-image/([a-z]+)/([a-z0-9-]+)\.jpg$ api/og-image.php?type=$1&slug=$2 [L]

# ================================================
# YML –§–Ш–Ф–Ђ –Ф–Ы–ѓ –ѓ–Э–Ф–Х–Ъ–° –Ф–Ш–†–Х–Ъ–Ґ
# ================================================
RewriteRule ^feeds/(competitions-ad|competitions|olympiads-ad|olympiads|courses-ad|courses|retraining-ad|webinars)\.yml$ api/feeds/yml.php?type=$1 [L]

# ================================================
# –У–Ы–Р–Т–Э–Р–ѓ –°–Ґ–†–Р–Э–Ш–¶–Р
# ================================================

# Magic Link auth (path-only —Д–Њ—А–Љ–∞—В: —Г—Б—В–Њ–є—З–Є–≤ –Ї –Љ–∞–љ–≥–µ–ї–Є–љ–≥—Г URL –≤ —А–µ–і–Є—А–µ–Ї—В–Њ—А–∞—Е Unisender/Gmail/–∞–љ—В–Є—Б–њ–∞–Љ)
RewriteRule ^m/([A-Za-z0-9_-]+)/([A-Za-z0-9_-]+)/?$ pages/magic-auth.php?token=$1&r=$2 [L,QSA]
RewriteRule ^m/([A-Za-z0-9_-]+)/?$ pages/magic-auth.php?token=$1 [L,QSA]

# Email click-tracker (path-only —Д–Њ—А–Љ–∞—В, –∞–љ–∞–ї–Њ–≥–Є—З–љ–Њ magic)
RewriteRule ^c/([a-f0-9]{32})/([A-Za-z0-9_-]+)/?$ api/email-track/click.php?mid=$1&u=$2 [L,QSA]

# SEO files
RewriteRule ^robots\.txt$ robots.php [L]
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# 301 /index.php вЖТ / (–Є–Ј–±–µ–≥–∞–µ–Љ –і—Г–±–ї–Є–Ї–∞—В–∞ –≥–ї–∞–≤–љ–Њ–є –і–ї—П Google)
RewriteCond %{THE_REQUEST} \s/+index\.php[\s?]
RewriteRule ^index\.php$ / [R=301,L]

# –У–ї–∞–≤–љ–∞—П —Б—В—А–∞–љ–Є—Ж–∞ –њ–Њ—А—В–∞–ї–∞
RewriteRule ^$ index.php [L]

# ================================================
# –Ъ–Ю–Э–Ъ–£–†–°–Ђ
# ================================================

# –°–њ–Є—Б–Њ–Ї –Ї–Њ–љ–Ї—Г—А—Б–Њ–≤
RewriteRule ^konkursy/?$ competitions.php [L,QSA]

# 301 —Б–Њ —Б—В–∞—А–Њ–≥–Њ –њ–Њ—А—П–і–Ї–∞ ac/at/as вЖТ –љ–Њ–≤—Л–є ac/as/at
# –†–∞—Б–њ–Њ–Ј–љ–∞—С–Љ –њ–Њ —Д–∞–Ї—В—Г: 2-–є —Б–µ–≥–Љ–µ–љ—В –њ–Њ—Б–ї–µ ac/cc вАФ —Б–ї–∞–≥ —В–Є–њ–∞ –Є–Ј –Ј–∞–Ї—А—Л—В–Њ–≥–Њ –Љ–љ–Њ–ґ–µ—Б—В–≤–∞
RewriteRule ^konkursy/(metodika|vneurochnaya|proekty|tvorchestvo)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo)/([a-z0-9-]+)/?$ /konkursy/$1/$2/$4/$3/ [R=301,L]
RewriteRule ^konkursy/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo)/([a-z0-9-]+)/?$ /konkursy/$1/$3/$2/ [R=301,L]

# –Ъ–∞—В–µ–≥–Њ—А–Є—П –Ї–Њ–љ–Ї—Г—А—Б–∞ + –∞—Г–і–Є—В–Њ—А–Є—П (–љ–Њ–≤—Л–є –њ–Њ—А—П–і–Њ–Ї): /konkursy/metodika/pedagogi/matematika/nachalnaya-shkola/
RewriteRule ^konkursy/(metodika|vneurochnaya|proekty|tvorchestvo)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ competitions.php?cc=$1&ac=$2&as=$3&at=$4 [L,QSA]
# 3-—Б–µ–≥–Љ–µ–љ—В–љ—Л–є: cc/ac/{slug} вАФ –µ—Б–ї–Є slug = —В–Є–њ, —Н—В–Њ —Г—А–Њ–≤–µ–љ—М –±–µ–Ј —Б–њ–µ—Ж–Є–∞–ї–Є–Ј–∞—Ж–Є–Є; –Є–љ–∞—З–µ —Б–њ–µ—Ж–Є–∞–ї–Є–Ј–∞—Ж–Є—П
RewriteRule ^konkursy/(metodika|vneurochnaya|proekty|tvorchestvo)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo)/?$ competitions.php?cc=$1&ac=$2&at=$3 [L,QSA]
RewriteRule ^konkursy/(metodika|vneurochnaya|proekty|tvorchestvo)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ competitions.php?cc=$1&ac=$2&as=$3 [L,QSA]
RewriteRule ^konkursy/(metodika|vneurochnaya|proekty|tvorchestvo)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ competitions.php?cc=$1&ac=$2 [L,QSA]

# –Ъ–∞—В–µ–≥–Њ—А–Є–Є –Ї–Њ–љ–Ї—Г—А—Б–Њ–≤ (–±–µ–Ј –∞—Г–і–Є—В–Њ—А–Є–Є)

# –Р–С-—В–µ—Б—В: –Ї–Њ–њ–Є—П —Б—В—А–∞–љ–Є—Ж—Л –Ї–Њ–љ–Ї—Г—А—Б–Њ–≤
RewriteRule ^konkursyb/?$ competitions-b.php [L,QSA]
RewriteRule ^konkursy/metodika/?$ competitions.php?category=methodology [L,QSA]
RewriteRule ^konkursy/vneurochnaya/?$ competitions.php?category=extracurricular [L,QSA]
RewriteRule ^konkursy/proekty/?$ competitions.php?category=student_projects [L,QSA]
RewriteRule ^konkursy/tvorchestvo/?$ competitions.php?category=creative [L,QSA]

# –Р—Г–і–Є—В–Њ—А–Є—П –Ї–Њ–љ–Ї—Г—А—Б–Њ–≤ (–љ–Њ–≤—Л–є –њ–Њ—А—П–і–Њ–Ї): /konkursy/pedagogi/matematika/nachalnaya-shkola/
RewriteRule ^konkursy/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ competitions.php?ac=$1&as=$2&at=$3 [L,QSA]
# 2-—Б–µ–≥–Љ–µ–љ—В–љ—Л–є: ac/{slug} вАФ –µ—Б–ї–Є slug = —В–Є–њ, —Н—В–Њ —Г—А–Њ–≤–µ–љ—М –±–µ–Ј —Б–њ–µ—Ж–Є–∞–ї–Є–Ј–∞—Ж–Є–Є; –Є–љ–∞—З–µ —Б–њ–µ—Ж–Є–∞–ї–Є–Ј–∞—Ж–Є—П
RewriteRule ^konkursy/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo)/?$ competitions.php?ac=$1&at=$2 [L,QSA]
RewriteRule ^konkursy/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ competitions.php?ac=$1&as=$2 [L,QSA]
RewriteRule ^konkursy/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ competitions.php?ac=$1 [L,QSA]

# –Ф–µ—В–∞–ї—М–љ–∞—П —Б—В—А–∞–љ–Є—Ж–∞ –Ї–Њ–љ–Ї—Г—А—Б–∞ (–µ–і–Є–љ—Л–є —Д–Њ—А–Љ–∞—В)
RewriteRule ^konkursy/([a-z0-9-]+)/?$ pages/competition-detail.php?slug=$1 [L,QSA]

# 301-—А–µ–і–Є—А–µ–Ї—В—Л —Б–Њ —Б—В–∞—А—Л—Е URL –Ї–Њ–љ–Ї—Г—А—Б–Њ–≤
RewriteRule ^konkurs/([a-z0-9-]+)/?$ /konkursy/$1 [R=301,L]
RewriteRule ^(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo)/konkurs/([a-z0-9-]+)/?$ /konkursy/$2 [R=301,L]

# 301-—А–µ–і–Є—А–µ–Ї—В —Б –њ—А—П–Љ–Њ–≥–Њ –і–Њ—Б—В—Г–њ–∞ –Ї competition-detail.php (—В–Њ–ї—М–Ї–Њ —А–µ–∞–ї—М–љ—Л–µ –Ј–∞–њ—А–Њ—Б—Л, –љ–µ –≤–љ—Г—В—А–µ–љ–љ–Є–µ rewrite)
RewriteCond %{THE_REQUEST} \s/pages/competition-detail\.php
RewriteCond %{QUERY_STRING} slug=([a-z0-9-]+)
RewriteRule ^pages/competition-detail\.php$ /konkursy/%1? [R=301,L]

# ================================================
# –Ю–Ы–Ш–Ь–Я–Ш–Р–Ф–Ђ
# ================================================

# –°–њ–Є—Б–Њ–Ї –Њ–ї–Є–Љ–њ–Є–∞–і
RewriteRule ^olimpiady/?$ olympiads.php [L,QSA]

# Legacy –Њ–ї–Є–Љ–њ–Є–∞–і–љ—Л–µ –Љ–∞—А—И—А—Г—В—Л вЖТ 301 –љ–∞ —З–Є—Б—В—Л–µ URL
RewriteRule ^olimpiady/pedagogam-dou/?$ /olimpiady/pedagogi/dou/ [R=301,L]
RewriteRule ^olimpiady/pedagogam-shkol/?$ /olimpiady/pedagogi/ [R=301,L]
RewriteRule ^olimpiady/pedagogam-ovz/?$ /olimpiady/pedagogi/ [R=301,L]
RewriteRule ^olimpiady/logopedy/?$ /olimpiady/pedagogi/ [R=301,L]

# 301 —Б–Њ —Б—В–∞—А–Њ–≥–Њ –њ–Њ—А—П–і–Ї–∞ ac/at/as вЖТ –љ–Њ–≤—Л–є ac/as/at
RewriteRule ^olimpiady/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo)/([a-z0-9-]+)/?$ /olimpiady/$1/$3/$2/ [R=301,L]

# –Р—Г–і–Є—В–Њ—А–Є—П –Њ–ї–Є–Љ–њ–Є–∞–і (–љ–Њ–≤—Л–є –њ–Њ—А—П–і–Њ–Ї): /olimpiady/pedagogi/matematika/nachalnaya-shkola/
RewriteRule ^olimpiady/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ olympiads.php?ac=$1&as=$2&at=$3 [L,QSA]
# 2-—Б–µ–≥–Љ–µ–љ—В–љ—Л–є: ac/{slug} вАФ –µ—Б–ї–Є slug = —В–Є–њ, —Н—В–Њ —Г—А–Њ–≤–µ–љ—М –±–µ–Ј —Б–њ–µ—Ж–Є–∞–ї–Є–Ј–∞—Ж–Є–Є
RewriteRule ^olimpiady/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo)/?$ olympiads.php?ac=$1&at=$2 [L,QSA]
RewriteRule ^olimpiady/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ olympiads.php?ac=$1&as=$2 [L,QSA]
RewriteRule ^olimpiady/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ olympiads.php?ac=$1 [L,QSA]

# –Ф–µ—В–∞–ї—М–љ–∞—П —Б—В—А–∞–љ–Є—Ж–∞ –Њ–ї–Є–Љ–њ–Є–∞–і—Л
RewriteRule ^olimpiady/([a-z0-9-]+)/?$ pages/olympiad-detail.php?slug=$1 [L,QSA]

# –Ґ–µ—Б—В –Њ–ї–Є–Љ–њ–Є–∞–і—Л
RewriteRule ^olimpiada-test/(\d+)/?$ pages/olympiad-test.php?olympiad_id=$1 [L,QSA]

# –†–µ–Ј—Г–ї—М—В–∞—В –Њ–ї–Є–Љ–њ–Є–∞–і—Л
RewriteRule ^olimpiada-rezultat/(\d+)/?$ pages/olympiad-result.php?result_id=$1 [L,QSA]

# –Ю—Д–Њ—А–Љ–ї–µ–љ–Є–µ –і–Є–њ–ї–Њ–Љ–∞ –Њ–ї–Є–Љ–њ–Є–∞–і—Л
RewriteRule ^olimpiada-diplom/(\d+)/?$ pages/olympiad-diploma.php?result_id=$1 [L,QSA]

# ================================================
# –Т–Х–С–Ш–Э–Р–†–Ђ
# ================================================

# –†–µ–і–Є—А–µ–Ї—В—Л —Б–Њ —Б—В–∞—А—Л—Е URL –∞–≤—В–Њ–≤–µ–±–Є–љ–∞—А–Њ–≤
RewriteRule ^vebinary/avtovebinary/?$ /vebinary/videolektsii/ [R=301,L]
RewriteRule ^kabinet/avtovebinar/(\d+)/?$ /kabinet/videolektsiya/$1/ [R=301,L]

# –°–њ–Є—Б–Њ–Ї –≤–µ–±–Є–љ–∞—А–Њ–≤
RewriteRule ^vebinary/?$ pages/webinars.php [L,QSA]

# 301 —Б–Њ —Б—В–∞—А–Њ–≥–Њ –њ–Њ—А—П–і–Ї–∞ ac/at/as вЖТ –љ–Њ–≤—Л–є ac/as/at
RewriteRule ^vebinary/(predstoyashchie|zapisi|videolektsii)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo)/([a-z0-9-]+)/?$ /vebinary/$1/$2/$4/$3/ [R=301,L]
RewriteRule ^vebinary/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo)/([a-z0-9-]+)/?$ /vebinary/$1/$3/$2/ [R=301,L]

# –°—В–∞—В—Г—Б + –∞—Г–і–Є—В–Њ—А–Є—П (–љ–Њ–≤—Л–є –њ–Њ—А—П–і–Њ–Ї): /vebinary/predstoyashchie/pedagogi/matematika/nachalnaya-shkola/
RewriteRule ^vebinary/(predstoyashchie|zapisi|videolektsii)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ pages/webinars.php?sc=$1&ac=$2&as=$3&at=$4 [L,QSA]
RewriteRule ^vebinary/(predstoyashchie|zapisi|videolektsii)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo)/?$ pages/webinars.php?sc=$1&ac=$2&at=$3 [L,QSA]
RewriteRule ^vebinary/(predstoyashchie|zapisi|videolektsii)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ pages/webinars.php?sc=$1&ac=$2&as=$3 [L,QSA]
RewriteRule ^vebinary/(predstoyashchie|zapisi|videolektsii)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ pages/webinars.php?sc=$1&ac=$2 [L,QSA]

# –Т–µ–±–Є–љ–∞—А—Л –њ–Њ —Б—В–∞—В—Г—Б—Г (–±–µ–Ј –∞—Г–і–Є—В–Њ—А–Є–Є)
RewriteRule ^vebinary/predstoyashchie/?$ pages/webinars.php?status=upcoming [L,QSA]
RewriteRule ^vebinary/zapisi/?$ pages/webinars.php?status=recordings [L,QSA]
RewriteRule ^vebinary/videolektsii/?$ pages/webinars.php?status=videolecture [L,QSA]

# –Р—Г–і–Є—В–Њ—А–Є—П –≤–µ–±–Є–љ–∞—А–Њ–≤ –±–µ–Ј —Б—В–∞—В—Г—Б–∞ (–љ–Њ–≤—Л–є –њ–Њ—А—П–і–Њ–Ї): /vebinary/pedagogi/matematika/nachalnaya-shkola/
RewriteRule ^vebinary/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ pages/webinars.php?ac=$1&as=$2&at=$3 [L,QSA]
RewriteRule ^vebinary/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo)/?$ pages/webinars.php?ac=$1&at=$2 [L,QSA]
RewriteRule ^vebinary/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ pages/webinars.php?ac=$1&as=$2 [L,QSA]
RewriteRule ^vebinary/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ pages/webinars.php?ac=$1 [L,QSA]

# –Ф–µ—В–∞–ї—М–љ–∞—П —Б—В—А–∞–љ–Є—Ж–∞ –≤–µ–±–Є–љ–∞—А–∞
RewriteRule ^vebinar/([a-z0-9-]+)/?$ pages/webinar.php?slug=$1 [L,QSA]

# ================================================
# –Ц–£–†–Э–Р–Ы / –Я–£–С–Ы–Ш–Ъ–Р–¶–Ш–Ш
# ================================================

# –Ц—Г—А–љ–∞–ї - –≥–ї–∞–≤–љ–∞—П
RewriteRule ^zhurnal/?$ pages/journal.php [L,QSA]

# –Р—Г–і–Є—В–Њ—А–Є—П –ґ—Г—А–љ–∞–ї–∞ (3 —Г—А–Њ–≤–љ—П): /zhurnal/pedagogi/dou/logopediya/
