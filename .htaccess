# Apache Configuration
# Enable URL Rewriting and Security Headers

# Enable Rewrite Engine
RewriteEngine On
RewriteBase /

# ================================================
# ИИ-КОНСУЛЬТАНТ (изолированный контейнер)
# ================================================
# Проксируем /ai-chat/api/* → ai-consultant:80/api/* через mod_proxy.
# Если контейнер упал — Apache вернёт 503, JS виджета покажет offline-баннер
# (ProxyPass не работает в .htaccess; используем RewriteRule с [P])
RewriteRule ^ai-chat/api/(.*)$ http://ai-consultant:80/api/$1 [P,L]

# HTTPS Redirect (пропускает localhost)
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{HTTP_HOST} !^localhost [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# ================================================
# OG-КАРТИНКИ ДЛЯ СОЦСЕТЕЙ
# ================================================
RewriteRule ^og-image/ad/([a-z]+)/([a-z0-9-]+)\.jpg$ api/og-image.php?mode=ad&type=$1&slug=$2 [L]
RewriteRule ^og-image/([a-z]+)/([a-z0-9-]+)\.jpg$ api/og-image.php?type=$1&slug=$2 [L]

# ================================================
# YML ФИДЫ ДЛЯ ЯНДЕКС ДИРЕКТ
# ================================================
RewriteRule ^feeds/(competitions-ad|competitions|olympiads-ad|olympiads|courses-ad|courses|retraining-ad|webinars)\.yml$ api/feeds/yml.php?type=$1 [L]

# ================================================
# ГЛАВНАЯ СТРАНИЦА
# ================================================

# SEO files
RewriteRule ^robots\.txt$ robots.php [L]
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# Главная страница портала
RewriteRule ^$ index.php [L]

# ================================================
# КОНКУРСЫ
# ================================================

# Список конкурсов
RewriteRule ^konkursy/?$ competitions.php [L,QSA]

# Категория конкурса + аудитория (3 уровня): /konkursy/metodika/pedagogi/dou/logopediya/
RewriteRule ^konkursy/(metodika|vneurochnaya|proekty|tvorchestvo)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ competitions.php?cc=$1&ac=$2&at=$3&as=$4 [L,QSA]
RewriteRule ^konkursy/(metodika|vneurochnaya|proekty|tvorchestvo)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ competitions.php?cc=$1&ac=$2&at=$3 [L,QSA]
RewriteRule ^konkursy/(metodika|vneurochnaya|proekty|tvorchestvo)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ competitions.php?cc=$1&ac=$2 [L,QSA]

# Категории конкурсов (без аудитории)

# АБ-тест: копия страницы конкурсов
RewriteRule ^konkursyb/?$ competitions-b.php [L,QSA]
RewriteRule ^konkursy/metodika/?$ competitions.php?category=methodology [L,QSA]
RewriteRule ^konkursy/vneurochnaya/?$ competitions.php?category=extracurricular [L,QSA]
RewriteRule ^konkursy/proekty/?$ competitions.php?category=student_projects [L,QSA]
RewriteRule ^konkursy/tvorchestvo/?$ competitions.php?category=creative [L,QSA]

# Аудитория конкурсов (3 уровня): /konkursy/pedagogi/dou/logopediya/
RewriteRule ^konkursy/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ competitions.php?ac=$1&at=$2&as=$3 [L,QSA]
RewriteRule ^konkursy/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ competitions.php?ac=$1&at=$2 [L,QSA]
RewriteRule ^konkursy/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ competitions.php?ac=$1 [L,QSA]

# Детальная страница конкурса (единый формат)
RewriteRule ^konkursy/([a-z0-9-]+)/?$ pages/competition-detail.php?slug=$1 [L,QSA]

# 301-редиректы со старых URL конкурсов
RewriteRule ^konkurs/([a-z0-9-]+)/?$ /konkursy/$1 [R=301,L]
RewriteRule ^(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo)/konkurs/([a-z0-9-]+)/?$ /konkursy/$2 [R=301,L]

# 301-редирект с прямого доступа к competition-detail.php (только реальные запросы, не внутренние rewrite)
RewriteCond %{THE_REQUEST} \s/pages/competition-detail\.php
RewriteCond %{QUERY_STRING} slug=([a-z0-9-]+)
RewriteRule ^pages/competition-detail\.php$ /konkursy/%1? [R=301,L]

# ================================================
# ОЛИМПИАДЫ
# ================================================

# Список олимпиад
RewriteRule ^olimpiady/?$ olympiads.php [L,QSA]

# Legacy олимпиадные маршруты → 301 на чистые URL
RewriteRule ^olimpiady/pedagogam-dou/?$ /olimpiady/pedagogi/dou/ [R=301,L]
RewriteRule ^olimpiady/pedagogam-shkol/?$ /olimpiady/pedagogi/ [R=301,L]
RewriteRule ^olimpiady/pedagogam-ovz/?$ /olimpiady/pedagogi/ [R=301,L]
RewriteRule ^olimpiady/logopedy/?$ /olimpiady/pedagogi/ [R=301,L]

# Аудитория олимпиад (3 уровня): /olimpiady/pedagogi/dou/logopediya/
RewriteRule ^olimpiady/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ olympiads.php?ac=$1&at=$2&as=$3 [L,QSA]
RewriteRule ^olimpiady/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ olympiads.php?ac=$1&at=$2 [L,QSA]
RewriteRule ^olimpiady/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ olympiads.php?ac=$1 [L,QSA]

# Детальная страница олимпиады
RewriteRule ^olimpiady/([a-z0-9-]+)/?$ pages/olympiad-detail.php?slug=$1 [L,QSA]

# Тест олимпиады
RewriteRule ^olimpiada-test/(\d+)/?$ pages/olympiad-test.php?olympiad_id=$1 [L,QSA]

# Результат олимпиады
RewriteRule ^olimpiada-rezultat/(\d+)/?$ pages/olympiad-result.php?result_id=$1 [L,QSA]

# Оформление диплома олимпиады
RewriteRule ^olimpiada-diplom/(\d+)/?$ pages/olympiad-diploma.php?result_id=$1 [L,QSA]

# ================================================
# ВЕБИНАРЫ
# ================================================

# Редиректы со старых URL автовебинаров
RewriteRule ^vebinary/avtovebinary/?$ /vebinary/videolektsii/ [R=301,L]
RewriteRule ^kabinet/avtovebinar/(\d+)/?$ /kabinet/videolektsiya/$1/ [R=301,L]

# Список вебинаров
RewriteRule ^vebinary/?$ pages/webinars.php [L,QSA]

# Статус + аудитория (3 уровня): /vebinary/predstoyashchie/pedagogi/dou/logopediya/
RewriteRule ^vebinary/(predstoyashchie|zapisi|videolektsii)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ pages/webinars.php?sc=$1&ac=$2&at=$3&as=$4 [L,QSA]
RewriteRule ^vebinary/(predstoyashchie|zapisi|videolektsii)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ pages/webinars.php?sc=$1&ac=$2&at=$3 [L,QSA]
RewriteRule ^vebinary/(predstoyashchie|zapisi|videolektsii)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ pages/webinars.php?sc=$1&ac=$2 [L,QSA]

# Вебинары по статусу (без аудитории)
RewriteRule ^vebinary/predstoyashchie/?$ pages/webinars.php?status=upcoming [L,QSA]
RewriteRule ^vebinary/zapisi/?$ pages/webinars.php?status=recordings [L,QSA]
RewriteRule ^vebinary/videolektsii/?$ pages/webinars.php?status=videolecture [L,QSA]

# Аудитория вебинаров без статуса (3 уровня): /vebinary/pedagogi/dou/logopediya/
RewriteRule ^vebinary/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ pages/webinars.php?ac=$1&at=$2&as=$3 [L,QSA]
RewriteRule ^vebinary/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ pages/webinars.php?ac=$1&at=$2 [L,QSA]
RewriteRule ^vebinary/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ pages/webinars.php?ac=$1 [L,QSA]

# Детальная страница вебинара
RewriteRule ^vebinar/([a-z0-9-]+)/?$ pages/webinar.php?slug=$1 [L,QSA]

# ================================================
# ЖУРНАЛ / ПУБЛИКАЦИИ
# ================================================

# Журнал - главная
RewriteRule ^zhurnal/?$ pages/journal.php [L,QSA]

# Аудитория журнала (3 уровня): /zhurnal/pedagogi/dou/logopediya/
RewriteRule ^zhurnal/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ pages/journal.php?ac=$1&at=$2&as=$3 [L,QSA]
RewriteRule ^zhurnal/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ pages/journal.php?ac=$1&at=$2 [L,QSA]
RewriteRule ^zhurnal/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ pages/journal.php?ac=$1 [L,QSA]

# Детальная страница публикации
RewriteRule ^publikaciya/([a-z0-9-]+)/?$ pages/publication.php?slug=$1 [L,QSA]

# Подача публикации
RewriteRule ^opublikovat/?$ pages/submit-publication.php [L,QSA]

# Генератор статей
RewriteRule ^generator-statej/?$ pages/article-generator.php [L,QSA]

# Сертификат публикации
RewriteRule ^sertifikat-publikacii/?$ pages/publication-certificate.php [L,QSA]

# Каталог опубликованных материалов
RewriteRule ^publikacii/?$ publications.php [L,QSA]

# Аудитория публикаций (3 уровня): /publikacii/pedagogi/dou/logopediya/
RewriteRule ^publikacii/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ publications.php?ac=$1&at=$2&as=$3 [L,QSA]
RewriteRule ^publikacii/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ publications.php?ac=$1&at=$2 [L,QSA]
RewriteRule ^publikacii/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ publications.php?ac=$1 [L,QSA]

# ================================================
# КУРСЫ ПОВЫШЕНИЯ КВАЛИФИКАЦИИ
# ================================================

# Список курсов
RewriteRule ^kursy/?$ courses.php [L,QSA]

# Тип программы + аудитория (3 уровня): /kursy/povyshenie-kvalifikatsii/pedagogi/dou/vospitatel/
RewriteRule ^kursy/(povyshenie-kvalifikatsii|perepodgotovka)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ courses.php?ct=$1&ac=$2&at=$3&as=$4 [L,QSA]
RewriteRule ^kursy/(povyshenie-kvalifikatsii|perepodgotovka)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ courses.php?ct=$1&ac=$2&at=$3 [L,QSA]
RewriteRule ^kursy/(povyshenie-kvalifikatsii|perepodgotovka)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ courses.php?ct=$1&ac=$2 [L,QSA]

# Типы программ (без аудитории)
RewriteRule ^kursy/povyshenie-kvalifikatsii/?$ courses.php?program_type=kpk [L,QSA]
RewriteRule ^kursy/perepodgotovka/?$ courses.php?program_type=pp [L,QSA]

# Аудитория курсов (3 уровня): /kursy/pedagogi/dou/vospitatel/
RewriteRule ^kursy/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ courses.php?ac=$1&at=$2&as=$3 [L,QSA]
RewriteRule ^kursy/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ courses.php?ac=$1&at=$2 [L,QSA]
RewriteRule ^kursy/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ courses.php?ac=$1 [L,QSA]

# Детальная страница курса
RewriteRule ^kursy/([a-z0-9-]+)/?$ pages/course-detail.php?slug=$1 [L,QSA]

# ================================================
# АУДИТОРИЯ
# ================================================

RewriteRule ^(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo|doshkolniki|1-4-klassy|5-8-klassy|9-11-klassy|studenty-spo|dopolnitelnoe-obrazovanie)/?$ pages/audience.php?slug=$1 [L,QSA]

# ================================================
# ЛИЧНЫЙ КАБИНЕТ И ДЕЙСТВИЯ
# ================================================

RewriteRule ^kabinet/?$ pages/cabinet.php [L,QSA]
RewriteRule ^kabinet/videolektsiya/(\d+)/?$ pages/cabinet-autowebinar.php?registration_id=$1 [L,QSA]
RewriteRule ^korzina/?$ pages/cart.php [L,QSA]
RewriteRule ^vhod/?$ pages/login.php [L,QSA]
RewriteRule ^vyhod/?$ pages/logout.php [L,QSA]

# ================================================
# СВЕДЕНИЯ ОБ ОРГАНИЗАЦИИ
# ================================================

RewriteRule ^svedeniya/?$ pages/svedeniya/index.php [L,QSA]
RewriteRule ^svedeniya/osnovnye-svedeniya/?$ pages/svedeniya/osnovnye-svedeniya.php [L,QSA]
RewriteRule ^svedeniya/struktura-i-organy-upravleniya/?$ pages/svedeniya/struktura.php [L,QSA]
RewriteRule ^svedeniya/dokumenty/?$ pages/svedeniya/dokumenty.php [L,QSA]
RewriteRule ^svedeniya/obrazovanie/?$ pages/svedeniya/obrazovanie.php [L,QSA]
RewriteRule ^svedeniya/obrazovatelnye-standarty/?$ pages/svedeniya/obrazovatelnye-standarty.php [L,QSA]
RewriteRule ^svedeniya/rukovodstvo/?$ pages/svedeniya/rukovodstvo.php [L,QSA]
RewriteRule ^svedeniya/materialno-tehnicheskoe-obespechenie/?$ pages/svedeniya/materialno-tehnicheskoe-obespechenie.php [L,QSA]
RewriteRule ^svedeniya/stipendii/?$ pages/svedeniya/stipendii.php [L,QSA]
RewriteRule ^svedeniya/platnye-obrazovatelnye-uslugi/?$ pages/svedeniya/platnye-uslugi.php [L,QSA]
RewriteRule ^svedeniya/fin-hoz-deyatelnost/?$ pages/svedeniya/fin-hoz-deyatelnost.php [L,QSA]
RewriteRule ^svedeniya/vakantnye-mesta/?$ pages/svedeniya/vakantnye-mesta.php [L,QSA]
RewriteRule ^svedeniya/mezhdunarodnoe-sotrudnichestvo/?$ pages/svedeniya/mezhdunarodnoe-sotrudnichestvo.php [L,QSA]
RewriteRule ^svedeniya/dostupnaya-sreda/?$ pages/svedeniya/dostupnaya-sreda.php [L,QSA]

# ================================================
# СЛУЖЕБНЫЕ СТРАНИЦЫ
# ================================================

RewriteRule ^o-portale/?$ pages/about.php [L,QSA]
RewriteRule ^polzovatelskoe-soglashenie/?$ pages/terms.php [L,QSA]
RewriteRule ^politika-konfidencialnosti/?$ pages/privacy.php [L,QSA]
RewriteRule ^oferta-kursy/?$ pages/oferta-courses.php [L,QSA]
RewriteRule ^oferta-meropriyatiya/?$ pages/oferta-events.php [L,QSA]
RewriteRule ^oferta-materialy/?$ pages/oferta-materials.php [L,QSA]

# Кастомная 404 страница
ErrorDocument 404 /pages/404.php

# Prevent direct access to sensitive files
<FilesMatch "\.(env|sql|md|log)$">
    Require all denied
</FilesMatch>

# Prevent directory listing
Options -Indexes

# Security Headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# PHP Security Settings
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag log_errors On
    php_value error_log /tmp/php_errors.log
</IfModule>

# Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Browser Caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/pdf "access plus 1 month"
</IfModule>
