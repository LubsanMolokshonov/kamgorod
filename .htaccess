# Apache Configuration
# Enable URL Rewriting and Security Headers

# Enable Rewrite Engine
RewriteEngine On
RewriteBase /

# ================================================
# ИИ-КОНСУЛЬТАНТ (изолированный контейнер)
# ================================================
# Проксируем /ai-chat/api/* → ai-consultant:80/api/* через mod_proxy.
# Если контейнер упал — Apache вернёт 503, JS виджета покажет offline-баннер
# (ProxyPass не работает в .htaccess; используем RewriteRule с [P])
RewriteRule ^ai-chat/api/(.*)$ http://ai-consultant:80/api/$1 [P,L]

# www → non-www (301) — не трогаем localhost
RewriteCond %{HTTP_HOST} !^localhost [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# HTTPS Redirect (пропускает localhost)
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{HTTP_HOST} !^localhost [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# ================================================
# APPLE UNIVERSAL LINKS (iOS-приложения у сайта нет)
# 410 Gone, чтобы iOS и GSC прекратили запросы.
# ВАЖНО: правило выше trailing-slash-редиректа — иначе запрос без слэша
# сначала редиректится на .../ (301) и 410 не срабатывает.
# ================================================
RewriteRule ^(\.well-known/)?apple-app-site-association$ - [R=410,L]

# Trailing slash: канонический URL — со слэшем на конце.
# Применяется только к GET/HEAD, к URL без расширения файла и не к существующим файлам/папкам.
# Явный https:// в Location — иначе Apache за nginx-прокси теряет схему и отдаёт http://
# На localhost оставляем http://, чтобы локальная разработка не требовала SSL.
RewriteCond %{REQUEST_METHOD} ^(GET|HEAD)$
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]+$
RewriteCond %{REQUEST_URI} !/$
RewriteCond %{HTTP_HOST} ^(localhost|127\.0\.0\.1) [NC]
RewriteRule ^(.+)$ http://%{HTTP_HOST}/$1/ [R=301,L]

RewriteCond %{REQUEST_METHOD} ^(GET|HEAD)$
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]+$
RewriteCond %{REQUEST_URI} !/$
RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1) [NC]
RewriteRule ^(.+)$ https://%{HTTP_HOST}/$1/ [R=301,L]

# ================================================
# OG-КАРТИНКИ ДЛЯ СОЦСЕТЕЙ
# ================================================
RewriteRule ^og-image/ad/([a-z]+)/([a-z0-9-]+)\.jpg$ api/og-image.php?mode=ad&type=$1&slug=$2 [L]
RewriteRule ^og-image/([a-z]+)/([a-z0-9-]+)\.jpg$ api/og-image.php?type=$1&slug=$2 [L]

# ================================================
# YML ФИДЫ ДЛЯ ЯНДЕКС ДИРЕКТ
# ================================================
RewriteRule ^feeds/(competitions-ad|competitions|olympiads-ad|olympiads|courses-ad|courses|retraining-ad|webinars)\.yml$ api/feeds/yml.php?type=$1 [L]

# ================================================
# ГЛАВНАЯ СТРАНИЦА
# ================================================

# Magic Link auth (path-only формат: устойчив к мангелингу URL в редиректорах Unisender/Gmail/антиспам)
RewriteRule ^m/([A-Za-z0-9_-]+)/([A-Za-z0-9_-]+)/?$ pages/magic-auth.php?token=$1&r=$2 [L,QSA]
RewriteRule ^m/([A-Za-z0-9_-]+)/?$ pages/magic-auth.php?token=$1 [L,QSA]

# Recovery link для failed-заказов (см. PaymentRecoveryChain). Path-формат как у /m/.
RewriteRule ^r/([A-Za-z0-9_-]+)/?$ pages/cart-restore.php?token=$1 [L,QSA]

# Email click-tracker (path-only формат, аналогично magic)
RewriteRule ^c/([a-f0-9]{32})/([A-Za-z0-9_-]+)/?$ api/email-track/click.php?mid=$1&u=$2 [L,QSA]

# SEO files
RewriteRule ^robots\.txt$ robots.php [L]
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# 301 /index.php → / (избегаем дубликата главной для Google)
RewriteCond %{THE_REQUEST} \s/+index\.php[\s?]
RewriteRule ^index\.php$ / [R=301,L]

# Главная страница портала
RewriteRule ^$ index.php [L]

# ================================================
# КОНКУРСЫ
# ================================================

# Список конкурсов
RewriteRule ^konkursy/?$ competitions.php [L,QSA]

# 301 со старого порядка ac/at/as → новый ac/as/at
# Распознаём по факту: 2-й сегмент после ac/cc — слаг типа из закрытого множества
RewriteRule ^konkursy/(metodika|vneurochnaya|proekty|tvorchestvo)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo)/([a-z0-9-]+)/?$ /konkursy/$1/$2/$4/$3/ [R=301,L]
RewriteRule ^konkursy/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo)/([a-z0-9-]+)/?$ /konkursy/$1/$3/$2/ [R=301,L]

# Категория конкурса + аудитория (новый порядок): /konkursy/metodika/pedagogi/matematika/nachalnaya-shkola/
RewriteRule ^konkursy/(metodika|vneurochnaya|proekty|tvorchestvo)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ competitions.php?cc=$1&ac=$2&as=$3&at=$4 [L,QSA]
# 3-сегментный: cc/ac/{slug} — если slug = тип, это уровень без специализации; иначе специализация
RewriteRule ^konkursy/(metodika|vneurochnaya|proekty|tvorchestvo)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo)/?$ competitions.php?cc=$1&ac=$2&at=$3 [L,QSA]
RewriteRule ^konkursy/(metodika|vneurochnaya|proekty|tvorchestvo)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ competitions.php?cc=$1&ac=$2&as=$3 [L,QSA]
RewriteRule ^konkursy/(metodika|vneurochnaya|proekty|tvorchestvo)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ competitions.php?cc=$1&ac=$2 [L,QSA]

# Категории конкурсов (без аудитории)

# АБ-тест: копия страницы конкурсов
RewriteRule ^konkursyb/?$ competitions-b.php [L,QSA]
RewriteRule ^konkursy/metodika/?$ competitions.php?category=methodology [L,QSA]
RewriteRule ^konkursy/vneurochnaya/?$ competitions.php?category=extracurricular [L,QSA]
RewriteRule ^konkursy/proekty/?$ competitions.php?category=student_projects [L,QSA]
RewriteRule ^konkursy/tvorchestvo/?$ competitions.php?category=creative [L,QSA]

# Аудитория конкурсов (новый порядок): /konkursy/pedagogi/matematika/nachalnaya-shkola/
RewriteRule ^konkursy/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ competitions.php?ac=$1&as=$2&at=$3 [L,QSA]
# 2-сегментный: ac/{slug} — если slug = тип, это уровень без специализации; иначе специализация
RewriteRule ^konkursy/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo)/?$ competitions.php?ac=$1&at=$2 [L,QSA]
RewriteRule ^konkursy/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ competitions.php?ac=$1&as=$2 [L,QSA]
RewriteRule ^konkursy/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ competitions.php?ac=$1 [L,QSA]

# Детальная страница конкурса (единый формат)
RewriteRule ^konkursy/([a-z0-9-]+)/?$ pages/competition-detail.php?slug=$1 [L,QSA]

# 301-редиректы со старых URL конкурсов
RewriteRule ^konkurs/([a-z0-9-]+)/?$ /konkursy/$1 [R=301,L]
RewriteRule ^(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo)/konkurs/([a-z0-9-]+)/?$ /konkursy/$2 [R=301,L]

# 301-редирект с прямого доступа к competition-detail.php (только реальные запросы, не внутренние rewrite)
RewriteCond %{THE_REQUEST} \s/pages/competition-detail\.php
RewriteCond %{QUERY_STRING} slug=([a-z0-9-]+)
RewriteRule ^pages/competition-detail\.php$ /konkursy/%1? [R=301,L]

# ================================================
# ОЛИМПИАДЫ
# ================================================

# Список олимпиад
RewriteRule ^olimpiady/?$ olympiads.php [L,QSA]

# Legacy олимпиадные маршруты → 301 на чистые URL
RewriteRule ^olimpiady/pedagogam-dou/?$ /olimpiady/pedagogi/dou/ [R=301,L]
RewriteRule ^olimpiady/pedagogam-shkol/?$ /olimpiady/pedagogi/ [R=301,L]
RewriteRule ^olimpiady/pedagogam-ovz/?$ /olimpiady/pedagogi/ [R=301,L]
RewriteRule ^olimpiady/logopedy/?$ /olimpiady/pedagogi/ [R=301,L]

# 301 со старого порядка ac/at/as → новый ac/as/at
RewriteRule ^olimpiady/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo|dopolnitelnoe-obrazovanie|doshkolniki|1-4-klassy|5-8-klassy|9-11-klassy|studenty-spo)/([a-z0-9-]+)/?$ /olimpiady/$1/$3/$2/ [R=301,L]

# Аудитория олимпиад (новый порядок): /olimpiady/pedagogi/matematika/nachalnaya-shkola/
RewriteRule ^olimpiady/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ olympiads.php?ac=$1&as=$2&at=$3 [L,QSA]
# 2-сегментный: ac/{slug} — если slug = тип, это уровень без специализации
RewriteRule ^olimpiady/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo|dopolnitelnoe-obrazovanie|doshkolniki|1-4-klassy|5-8-klassy|9-11-klassy|studenty-spo)/?$ olympiads.php?ac=$1&at=$2 [L,QSA]
RewriteRule ^olimpiady/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ olympiads.php?ac=$1&as=$2 [L,QSA]
RewriteRule ^olimpiady/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ olympiads.php?ac=$1 [L,QSA]

# Детальная страница олимпиады
RewriteRule ^olimpiady/([a-z0-9-]+)/?$ pages/olympiad-detail.php?slug=$1 [L,QSA]

# Тест олимпиады
RewriteRule ^olimpiada-test/(\d+)/?$ pages/olympiad-test.php?olympiad_id=$1 [L,QSA]

# Результат олимпиады
RewriteRule ^olimpiada-rezultat/(\d+)/?$ pages/olympiad-result.php?result_id=$1 [L,QSA]

# Оформление диплома олимпиады
RewriteRule ^olimpiada-diplom/(\d+)/?$ pages/olympiad-diploma.php?result_id=$1 [L,QSA]

# ================================================
# ВЕБИНАРЫ
# ================================================

# Редиректы со старых URL автовебинаров
RewriteRule ^vebinary/avtovebinary/?$ /vebinary/videolektsii/ [R=301,L]
RewriteRule ^kabinet/avtovebinar/(\d+)/?$ /kabinet/videolektsiya/$1/ [R=301,L]

# Список вебинаров
RewriteRule ^vebinary/?$ pages/webinars.php [L,QSA]

# 301 со старого порядка ac/at/as → новый ac/as/at
RewriteRule ^vebinary/(predstoyashchie|zapisi|videolektsii)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo)/([a-z0-9-]+)/?$ /vebinary/$1/$2/$4/$3/ [R=301,L]
RewriteRule ^vebinary/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo)/([a-z0-9-]+)/?$ /vebinary/$1/$3/$2/ [R=301,L]

# Статус + аудитория (новый порядок): /vebinary/predstoyashchie/pedagogi/matematika/nachalnaya-shkola/
RewriteRule ^vebinary/(predstoyashchie|zapisi|videolektsii)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ pages/webinars.php?sc=$1&ac=$2&as=$3&at=$4 [L,QSA]
RewriteRule ^vebinary/(predstoyashchie|zapisi|videolektsii)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo)/?$ pages/webinars.php?sc=$1&ac=$2&at=$3 [L,QSA]
RewriteRule ^vebinary/(predstoyashchie|zapisi|videolektsii)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ pages/webinars.php?sc=$1&ac=$2&as=$3 [L,QSA]
RewriteRule ^vebinary/(predstoyashchie|zapisi|videolektsii)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ pages/webinars.php?sc=$1&ac=$2 [L,QSA]

# Вебинары по статусу (без аудитории)
RewriteRule ^vebinary/predstoyashchie/?$ pages/webinars.php?status=upcoming [L,QSA]
RewriteRule ^vebinary/zapisi/?$ pages/webinars.php?status=recordings [L,QSA]
RewriteRule ^vebinary/videolektsii/?$ pages/webinars.php?status=videolecture [L,QSA]

# Аудитория вебинаров без статуса (новый порядок): /vebinary/pedagogi/matematika/nachalnaya-shkola/
RewriteRule ^vebinary/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ pages/webinars.php?ac=$1&as=$2&at=$3 [L,QSA]
RewriteRule ^vebinary/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo)/?$ pages/webinars.php?ac=$1&at=$2 [L,QSA]
RewriteRule ^vebinary/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ pages/webinars.php?ac=$1&as=$2 [L,QSA]
RewriteRule ^vebinary/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ pages/webinars.php?ac=$1 [L,QSA]

# 301 со старого slug вебинара 03.06.2026 (смена темы на «полезное лето»)
RewriteRule ^vebinar/leto-bez-stressa-osobye-deti/?$ /vebinar/poleznoe-leto-osobyj-rebenok/ [R=301,L]

# Детальная страница вебинара
RewriteRule ^vebinar/([a-z0-9-]+)/?$ pages/webinar.php?slug=$1 [L,QSA]

# ================================================
# ЖУРНАЛ / ПУБЛИКАЦИИ
# ================================================

# Журнал - главная
RewriteRule ^zhurnal/?$ pages/journal.php [L,QSA]

# Аудитория журнала (3 уровня): /zhurnal/pedagogi/dou/logopediya/
RewriteRule ^zhurnal/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ pages/journal.php?ac=$1&at=$2&as=$3 [L,QSA]
RewriteRule ^zhurnal/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ pages/journal.php?ac=$1&at=$2 [L,QSA]
RewriteRule ^zhurnal/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ pages/journal.php?ac=$1 [L,QSA]

# Детальная страница публикации
# Канонический URL — со слэшем на конце. Без слэша — 301-редирект.
RewriteRule ^publikaciya/([a-z0-9-]+)$ /publikaciya/$1/ [R=301,L]
RewriteRule ^publikaciya/([a-z0-9-]+)/$ pages/publication.php?slug=$1 [L,QSA]

# Страница автора публикаций
RewriteRule ^avtor/([0-9]+)$ /avtor/$1/ [R=301,L]
RewriteRule ^avtor/([0-9]+)/$ pages/author.php?id=$1 [L,QSA]

# Подача публикации
RewriteRule ^opublikovat/?$ pages/submit-publication.php [L,QSA]

# ================================================
# МАТЕРИАЛЫ ФОП (каталог + ИИ-генератор)
# ================================================

# Лендинг раздела «Материалы ФОП»
RewriteRule ^materialy/?$ pages/materials-landing.php [L,QSA]

# Каталог материалов
RewriteRule ^materialy/katalog/?$ pages/materials-catalog.php [L,QSA]

# Каталог по типу материала: /materialy/katalog/tip/konspekt-uroka/
RewriteRule ^materialy/katalog/tip/([a-z0-9-]+)/?$ pages/materials-catalog.php?type=$1 [L,QSA]

# Аудитория каталога (3 уровня): /materialy/katalog/pedagogi/dou/logopediya/
RewriteRule ^materialy/katalog/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ pages/materials-catalog.php?ac=$1&at=$2&as=$3 [L,QSA]
RewriteRule ^materialy/katalog/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ pages/materials-catalog.php?ac=$1&at=$2 [L,QSA]
RewriteRule ^materialy/katalog/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ pages/materials-catalog.php?ac=$1 [L,QSA]

# 301 со старых path-based URL каталога (до переноса под /katalog/)
RewriteRule ^materialy/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)(/.*)?$ /materialy/katalog/$1$2 [R=301,L]

# Детальная страница материала
# Канонический URL — со слэшем на конце. Без слэша — 301-редирект.
RewriteRule ^material/([a-z0-9-]+)$ /material/$1/ [R=301,L]
RewriteRule ^material/([a-z0-9-]+)/$ pages/material-detail.php?slug=$1 [L,QSA]

# ИИ-генератор материалов
RewriteRule ^material-generator/?$ pages/material-generator.php [L,QSA]
RewriteRule ^material-generator/([a-z0-9-]+)/?$ pages/material-generator-form.php?type_slug=$1 [L,QSA]

# Раздача файлов материалов
RewriteRule ^material-download\.php$ pages/material-download.php [L,QSA]

# Личный кабинет токенов
RewriteRule ^material-balance/?$ pages/material-balance.php [L,QSA]

# Подписка (тарифы Базовый / Про)
RewriteRule ^podpiska/?$ pages/subscription.php [L,QSA]

# Адаптация материала
RewriteRule ^material-adapter/?$ pages/material-adapter.php [L,QSA]

# Генератор статей
RewriteRule ^generator-statej/?$ pages/article-generator.php [L,QSA]

# Сертификат публикации
RewriteRule ^sertifikat-publikacii/?$ pages/publication-certificate.php [L,QSA]

# Каталог опубликованных материалов
RewriteRule ^publikacii/?$ publications.php [L,QSA]

# Аудитория публикаций (3 уровня): /publikacii/pedagogi/dou/logopediya/
RewriteRule ^publikacii/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ publications.php?ac=$1&at=$2&as=$3 [L,QSA]
RewriteRule ^publikacii/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ publications.php?ac=$1&at=$2 [L,QSA]
RewriteRule ^publikacii/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ publications.php?ac=$1 [L,QSA]

# ================================================
# КУРСЫ ПОВЫШЕНИЯ КВАЛИФИКАЦИИ
# ================================================

# Список курсов
RewriteRule ^kursy/?$ courses.php [L,QSA]

# Редизайн A/B-варианта /kursyb/ промоутнут в основной /kursy/ — 301-редирект для устаревших ссылок
RewriteRule ^kursyb(/.*)?$ /kursy$1 [R=301,L]

# Тип программы + аудитория (3 уровня): /kursy/povyshenie-kvalifikatsii/pedagogi/dou/vospitatel/
RewriteRule ^kursy/(povyshenie-kvalifikatsii|perepodgotovka)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ courses.php?ct=$1&ac=$2&at=$3&as=$4 [L,QSA]
RewriteRule ^kursy/(povyshenie-kvalifikatsii|perepodgotovka)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ courses.php?ct=$1&ac=$2&at=$3 [L,QSA]
RewriteRule ^kursy/(povyshenie-kvalifikatsii|perepodgotovka)/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ courses.php?ct=$1&ac=$2 [L,QSA]

# Типы программ (без аудитории)
RewriteRule ^kursy/povyshenie-kvalifikatsii/?$ courses.php?program_type=kpk [L,QSA]
RewriteRule ^kursy/perepodgotovka/?$ courses.php?program_type=pp [L,QSA]

# Аудитория курсов (3 уровня): /kursy/pedagogi/dou/vospitatel/
RewriteRule ^kursy/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/([a-z0-9-]+)/?$ courses.php?ac=$1&at=$2&as=$3 [L,QSA]
RewriteRule ^kursy/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/([a-z0-9-]+)/?$ courses.php?ac=$1&at=$2 [L,QSA]
RewriteRule ^kursy/(pedagogi|doshkolnikam|shkolnikam|studentam-spo)/?$ courses.php?ac=$1 [L,QSA]

# Уровень (audience_type) без категории: /kursy/nachalnaya-shkola/, /kursy/perepodgotovka/nachalnaya-shkola/
RewriteRule ^kursy/(povyshenie-kvalifikatsii|perepodgotovka)/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo|dopolnitelnoe-obrazovanie)/([a-z0-9-]+)/?$ courses.php?ct=$1&at=$2&as=$3 [L,QSA]
RewriteRule ^kursy/(povyshenie-kvalifikatsii|perepodgotovka)/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo|dopolnitelnoe-obrazovanie)/?$ courses.php?ct=$1&at=$2 [L,QSA]
RewriteRule ^kursy/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo|dopolnitelnoe-obrazovanie)/([a-z0-9-]+)/?$ courses.php?at=$1&as=$2 [L,QSA]
RewriteRule ^kursy/(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo|dopolnitelnoe-obrazovanie)/?$ courses.php?at=$1 [L,QSA]

# Тип программы + специализация (без выбранной аудитории/уровня): /kursy/perepodgotovka/matematika/
RewriteRule ^kursy/(povyshenie-kvalifikatsii|perepodgotovka)/([a-z0-9-]+)/?$ courses.php?ct=$1&as=$2 [L,QSA]

# Детальная страница курса
RewriteRule ^kursy/([a-z0-9-]+)/?$ pages/course-detail.php?slug=$1 [L,QSA]

# ================================================
# АУДИТОРИЯ
# ================================================

RewriteRule ^(dou|nachalnaya-shkola|srednyaya-starshaya-shkola|spo|doshkolniki|1-4-klassy|5-8-klassy|9-11-klassy|studenty-spo|dopolnitelnoe-obrazovanie)/?$ pages/audience.php?slug=$1 [L,QSA]

# ================================================
# ЛИЧНЫЙ КАБИНЕТ И ДЕЙСТВИЯ
# ================================================

RewriteRule ^kabinet/?$ pages/cabinet.php [L,QSA]
RewriteRule ^kabinet/videolektsiya/(\d+)/?$ pages/cabinet-autowebinar.php?registration_id=$1 [L,QSA]
RewriteRule ^korzina/?$ pages/cart.php [L,QSA]
RewriteRule ^vhod/?$ pages/login.php [L,QSA]
RewriteRule ^vyhod/?$ pages/logout.php [L,QSA]

# ================================================
# СВЕДЕНИЯ ОБ ОРГАНИЗАЦИИ
# ================================================

RewriteRule ^svedeniya/?$ pages/svedeniya/index.php [L,QSA]
RewriteRule ^svedeniya/osnovnye-svedeniya/?$ pages/svedeniya/osnovnye-svedeniya.php [L,QSA]
RewriteRule ^svedeniya/struktura-i-organy-upravleniya/?$ pages/svedeniya/struktura.php [L,QSA]
RewriteRule ^svedeniya/dokumenty/?$ pages/svedeniya/dokumenty.php [L,QSA]
RewriteRule ^svedeniya/obrazovanie/?$ pages/svedeniya/obrazovanie.php [L,QSA]
RewriteRule ^svedeniya/obrazovatelnye-standarty/?$ pages/svedeniya/obrazovatelnye-standarty.php [L,QSA]
RewriteRule ^svedeniya/rukovodstvo/?$ pages/svedeniya/rukovodstvo.php [L,QSA]
RewriteRule ^svedeniya/materialno-tehnicheskoe-obespechenie/?$ pages/svedeniya/materialno-tehnicheskoe-obespechenie.php [L,QSA]
RewriteRule ^svedeniya/stipendii/?$ pages/svedeniya/stipendii.php [L,QSA]
RewriteRule ^svedeniya/platnye-obrazovatelnye-uslugi/?$ pages/svedeniya/platnye-uslugi.php [L,QSA]
RewriteRule ^svedeniya/fin-hoz-deyatelnost/?$ pages/svedeniya/fin-hoz-deyatelnost.php [L,QSA]
RewriteRule ^svedeniya/vakantnye-mesta/?$ pages/svedeniya/vakantnye-mesta.php [L,QSA]
RewriteRule ^svedeniya/mezhdunarodnoe-sotrudnichestvo/?$ pages/svedeniya/mezhdunarodnoe-sotrudnichestvo.php [L,QSA]
RewriteRule ^svedeniya/dostupnaya-sreda/?$ pages/svedeniya/dostupnaya-sreda.php [L,QSA]

# ================================================
# СЛУЖЕБНЫЕ СТРАНИЦЫ
# ================================================

RewriteRule ^o-portale/?$ pages/about.php [L,QSA]
RewriteRule ^polzovatelskoe-soglashenie/?$ pages/terms.php [L,QSA]
RewriteRule ^politika-konfidencialnosti/?$ pages/privacy.php [L,QSA]
RewriteRule ^oferta-kursy/?$ pages/oferta-courses.php [L,QSA]
RewriteRule ^oferta-meropriyatiya/?$ pages/oferta-events.php [L,QSA]
RewriteRule ^oferta-materialy/?$ pages/oferta-materials.php [L,QSA]
RewriteRule ^team/?$ pages/team.php [L,QSA]
RewriteRule ^komanda/?$ /team [R=301,L]

# Кастомная 404 страница
ErrorDocument 404 /pages/404.php

# Prevent direct access to sensitive files
<FilesMatch "\.(env|sql|md|log)$">
    Require all denied
</FilesMatch>

# Prevent directory listing
Options -Indexes

# Security Headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    # HSTS. TLS терминируется на фронтовом nginx, поэтому внутри Apache %{HTTPS} != on —
    # ставим безусловно (клиент всё равно получает ответ только по HTTPS через nginx,
    # а по HTTP браузеры HSTS игнорируют).
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    # CSP в режиме Report-Only: не ломает вёрстку, копит нарушения для дальнейшего
    # ужесточения. После анализа отчётов заменить на боевой Content-Security-Policy.
    Header set Content-Security-Policy-Report-Only "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; font-src 'self' data: https:; frame-ancestors 'self'"
</IfModule>

# PHP Security Settings
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag log_errors On
    php_value error_log /tmp/php_errors.log
</IfModule>

# Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# MIME для шрифтов (страховка: в базовом образе может не быть)
AddType font/woff2 .woff2
AddType font/woff .woff

# Browser Caching через mod_headers.
# mod_expires в образе НЕ включён (Dockerfile: a2enmod без expires), поэтому
# заголовки ставим напрямую. CSS/JS версионируются ?v=filemtime (см.
# includes/asset-helpers.php) — им можно год + immutable. Картинки без
# версионирования — 30 дней. PHP-страницы не задеваются: FilesMatch матчится
# по имени файла, а сессии шлют собственный no-cache.
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|mjs)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(woff2?|ttf|otf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(jpe?g|png|gif|webp|avif|svg|ico)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
</IfModule>
