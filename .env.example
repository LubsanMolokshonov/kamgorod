# Database Configuration
DB_HOST=localhost
DB_NAME=pedagogy_platform
DB_USER=your_db_user
DB_PASS=your_db_password

# Site Configuration
SITE_URL=http://localhost
SITE_NAME=Педагогический портал

# Yookassa Payment Gateway
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
YOOKASSA_MODE=sandbox

# Email SMTP Configuration (транзакционные письма — оплаты, документы, поддержка)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USERNAME=info@yoursite.ru
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=info@yoursite.ru
SMTP_FROM_NAME=Педагогический портал

# Bulk SMTP Pool (массовые рассылки — cron-цепочки, кампании)
# Ротация по двум ящикам Яндекс 360 для обхода лимита 500 писем/час
# и распределения нагрузки на репутации. Если оставить пустыми — массовые
# рассылки автоматически пойдут через основной SMTP_* (для совместимости).
SMTP_BULK_HOST=smtp.yandex.ru
SMTP_BULK_PORT=465
SMTP_BULK_USERNAME_1=mail1@yoursite.ru
SMTP_BULK_PASSWORD_1=app_password_1
SMTP_BULK_USERNAME_2=mail2@yoursite.ru
SMTP_BULK_PASSWORD_2=app_password_2

# Session Configuration
SESSION_LIFETIME=86400
COOKIE_LIFETIME=2592000

# Magic Link (auto-login from email links)
MAGIC_LINK_SECRET=your_random_secret_here

# Admin Configuration (default admin credentials)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
