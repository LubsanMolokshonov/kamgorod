# =============================================================================
# fgos.pro — пример .env
# Скопируйте этот файл в .env и заполните своими значениями.
# .env в git НЕ коммитится (см. .gitignore).
# =============================================================================

# --- База данных (MySQL 8, utf8mb4) ---
DB_HOST=db
DB_NAME=pedagogy_platform
DB_USER=pedagogy_user
DB_PASS=change_me_strong_password
# Используется только docker-compose для контейнера БД
DB_ROOT_PASS=change_me_strong_root_password

# --- Сайт ---
SITE_URL=http://localhost:8080
SITE_NAME=Педагогический портал
APP_ENV=local

# --- Yookassa (приём платежей) ---
# Получить в личном кабинете https://yookassa.ru/my
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
# sandbox | production. ВАЖНО: при production отключается display_errors.
YOOKASSA_MODE=sandbox

# --- Bitrix24 CRM ---
# Webhook URL вида https://<portal>.bitrix24.ru/rest/<user_id>/<token>/
BITRIX24_WEBHOOK_URL=
BITRIX24_WEBINAR_PIPELINE_ID=102
BITRIX24_COURSE_PIPELINE_ID=108
# Стадия для заявок на рассрочку (если своя — указать ID, иначе fallback на менеджерскую)
BITRIX24_COURSE_STAGE_INSTALLMENT=

# --- Messenger Max (контакт менеджера курсов) ---
# Используется в CTA после оплаты курса и заявки на рассрочку.
MAX_MANAGER_PHONE=+7 922 304 44 13
MAX_MANAGER_URL=https://max.ru/u/f9LHodD0cOJKXZhXUQImrGumTp40Eiu4o40RTZGhnpMVWgNe6tGt0x0OSco

# --- Unisender Go (UniOne) — единственный канал исходящих писем ---
# Все email (транзакционные + цепочки) идут через него. Никаких SMTP.
UNISENDER_API_KEY=
UNISENDER_API_ENDPOINT=https://go2.unisender.ru/ru/transactional/api/v1/
UNISENDER_SENDER_EMAIL=info@fgos.pro
UNISENDER_SENDER_NAME=ФГОС-Практикум

# Логический from-адрес сайта (используется AlertService и т.п.)
# Если не задано — fallback на UNISENDER_SENDER_*
SMTP_FROM_EMAIL=info@fgos.pro
SMTP_FROM_NAME=ФГОС-Практикум

# --- IMAP (приём входящих писем поддержки на info@fgos.pro) ---
# Используется cron/process-inbound-emails.php. Яндекс 360.
IMAP_HOST=imap.yandex.ru
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_ENCRYPTION=ssl
IMAP_MAILBOX=INBOX

# --- Yandex GPT (модерация контента, ИИ-консультант) ---
YANDEX_GPT_API_KEY=
YANDEX_GPT_FOLDER_ID=
YANDEX_GPT_MODEL=yandexgpt-lite

# --- OpenRouter (генератор материалов ФОП) ---
# Получить ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL_DEFAULT=meta-llama/llama-3.3-70b-instruct
OPENROUTER_MODEL_STRUCTURED=qwen/qwen-2.5-72b-instruct
OPENROUTER_MODEL_FAST=google/gemini-2.0-flash-001

# --- Telegram (тех. алерты в бот) ---
# Получить токен у @BotFather (/newbot или /mybots)
TELEGRAM_BOT_TOKEN=
# Comma-separated: ID получателей. Личный chat_id — у @userinfobot.
TELEGRAM_ALERT_CHAT_ID=

# --- ВКонтакте Callback API (алерты из сообщений группы) ---
VK_CALLBACK_SECRET=
VK_CONFIRMATION_STRING=
VK_COMMUNITY_TOKEN=
VK_GROUP_ID=0

# --- Сессии и cookies ---
SESSION_LIFETIME=86400
COOKIE_LIFETIME=2592000

# --- Magic Link (auto-login по ссылке из email) ---
# СГЕНЕРИРОВАТЬ: openssl rand -hex 32
MAGIC_LINK_SECRET=

# --- HMAC-секрет для скидочных ссылок в email-цепочке курсов ---
# СГЕНЕРИРОВАТЬ: openssl rand -hex 32
COURSE_EMAIL_DISCOUNT_SECRET=

# --- A/B-тест цен курсов (отключён, оставлено на случай повторного включения) ---
# СГЕНЕРИРОВАТЬ: openssl rand -hex 16
COURSE_AB_TEST_SECRET=

# --- Защитные лимиты email-цепочек (0 = отключено) ---
# Минимальный интервал между chain-письмами одному получателю (минуты)
CHAIN_MIN_INTERVAL_MINUTES=0
# Максимум chain-писем одному получателю за 24 часа
CHAIN_DAILY_CAP_PER_RECIPIENT=0
